# Server bind address. Use 127.0.0.1 for local dev, 0.0.0.0 for Docker or reverse proxies.
HOST=127.0.0.1

# Port the server listens on.
PORT=3000

# Must match the public-facing origin(s). Comma-separated for multiple.
ORIGIN=http://localhost:5173

# Deployment mode: "development" (build from source) or "production" (pull prebuilt image).
NODE_ENV=development
