# Server bind address. Use 127.0.0.1 for local dev, 0.0.0.0 for Docker or reverse proxies.
HOST=127.0.0.1

# Port the server listens on.
PORT=3000

# Must match the public-facing origin that your reverse proxy exposes.
ORIGIN=https://soundboard.example.com

# Absolute path to audio samples directory. Defaults to client/dist/samples if unset.
# SAMPLES_DIR=/path/to/your/audio/files
