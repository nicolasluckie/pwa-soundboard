# Server bind address. Use 127.0.0.1 for local dev, 0.0.0.0 for Docker or reverse proxies.
HOST=0.0.0.0

# Port the server listens on.
PORT=3000

# Must match the public-facing origin(s). Comma-separated for multiple.
ORIGIN=https://soundboard.example.com

# Deployment mode: "development" or "production".
NODE_ENV=production

# Sound sources: "demo,user" (both), "demo" (repo only), "user" (personal only)
SOURCES=user

# Data directory path (defaults to ../data relative to server).
# Set to /data in Docker to match the volume mount.
DATA_DIR=/data

# MongoDB connection URI. Use the Docker service name as hostname in production.
MONGODB_URI=mongodb://mongo:27017/soundboard
