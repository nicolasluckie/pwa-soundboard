{
  "name": "pwa-soundboard",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "postinstall": "npm install --prefix client && npm install --prefix server",
    "prepare": "husky",
    "commit": "cz",
    "dev": "concurrently \"npm run dev --prefix client\" \"npm start --prefix server\"",
    "build": "npm run build --prefix client",
    "start": "npm start --prefix server",
    "lint": "npm run lint --prefix client",
    "format": "npm run format --prefix client",
    "test:unit": "npm run test:unit --prefix client",
    "test:unit:coverage": "npm run test:unit:coverage --prefix client",
    "test:e2e": "npm run test:e2e --prefix client",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "client/**/*.{js,jsx}": [
      "npm exec --prefix client -- prettier --write",
      "npm exec --prefix client -- eslint --fix --config client/.eslintrc.cjs --resolve-plugins-relative-to client"
    ],
    "*.{json,md,yaml,yml,css}": [
      "npm exec --prefix client -- prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "commitizen": "^4.3.2",
    "concurrently": "^10.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
